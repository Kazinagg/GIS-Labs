unit Unit1;

interface

uses
  System.SysUtils, System.Types, System.UITypes, System.Classes, System.Variants,
  FMX.Types, FMX.Controls, FMX.Forms, FMX.Graphics, FMX.Dialogs, System.Sensors,
  FMX.StdCtrls, FMX.Controls.Presentation, FMX.WebBrowser,
  System.Sensors.Components;

type
  TForm1 = class(TForm)
    LocationSensor1: TLocationSensor;
    WebBrowser1: TWebBrowser;
    LabelCoords: TLabel;
    Panel1: TPanel;
    LabelCountry: TLabel;
    LabelCity: TLabel;
    LabelStreet: TLabel;
  procedure FormShow(Sender: TObject);
    procedure LocationSensor1LocationChanged(Sender: TObject;
      const OldLocation, NewLocation: TLocationCoord2D);
  private
    FGeocoder: TGeocoder;
    procedure OnGeocodeReverseEvent(const Address: TCivicAddress);
  public
    constructor Create(AOwner: TComponent); override;
    destructor Destroy; override;
  end;

var
  Form1: TForm1;

implementation

{$R *.fmx}

constructor TForm1.Create(AOwner: TComponent);
begin
  inherited;
  FGeocoder := nil; // Инициализируем пустотой
end;

destructor TForm1.Destroy;
begin
  if Assigned(FGeocoder) then
    FGeocoder.Free; // Очищаем память при закрытии
  inherited;
end;

// При показе формы включаем GPS
procedure TForm1.FormShow(Sender: TObject);
begin
  LocationSensor1.Active := True;
end;

// Когда сенсор получил координаты
procedure TForm1.LocationSensor1LocationChanged(Sender: TObject;
  const OldLocation, NewLocation: TLocationCoord2D);
var
  URL, LatStr, LonStr: string;
  FS: TFormatSettings;
begin
  // Обязательно ставим точку вместо запятой для Google Maps
  FS := TFormatSettings.Create('en-US');
  LatStr := FloatToStr(NewLocation.Latitude, FS);
  LonStr := FloatToStr(NewLocation.Longitude, FS);

  LabelCoords.Text := Format('Широта: %s Долгота: %s', [LatStr, LonStr]);

  // Загружаем карту в браузер
  URL := Format('https://maps.google.com/maps?q=%s,%s&output=embed', [LatStr, LonStr]);
  WebBrowser1.Navigate(URL);

  // Инициализируем геокодер
  if not Assigned(FGeocoder) then
  begin
    if Assigned(TGeocoder.Current) then
    begin
      FGeocoder := TGeocoder.Current.Create;
      FGeocoder.OnGeocodeReverse := OnGeocodeReverseEvent;
    end;
  end;

  // Отправляем запрос на получение улицы по координатам
  if Assigned(FGeocoder) and not FGeocoder.Geocoding then
    FGeocoder.GeocodeReverse(NewLocation);
end;

// Когда сервер Google вернул нам расшифрованный адрес
procedure TForm1.OnGeocodeReverseEvent(const Address: TCivicAddress);
begin
  if Assigned(Address) then
  begin
    LabelCountry.Text := 'Страна: ' + Address.CountryCode + ' / ' + Address.CountryName;
    LabelCity.Text := 'Город: ' + Address.AdminArea + ' / ' + Address.Locality;
    LabelStreet.Text := 'Улица: ' + Address.Thoroughfare + ', ' + Address.SubThoroughfare;
  end;
end;

end.
